# ============================================================
# Velum — Production environment variables
# Скопируй в .env, ОБЯЗАТЕЛЬНО смени все пароли!
# ============================================================

# PostgreSQL — СМЕНИТЬ ПАРОЛЬ!
POSTGRES_DB=semaphore
POSTGRES_USER=semaphore
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT — СМЕНИТЬ НА СЛУЧАЙНУЮ СТРОКУ (минимум 32 символа)
# Генерация: openssl rand -hex 32
SEMAPHORE_JWT_SECRET=CHANGE_ME_RANDOM_SECRET_AT_LEAST_32_CHARS

# Первоначальный администратор
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
SEMAPHORE_ADMIN_NAME=Administrator
SEMAPHORE_ADMIN_EMAIL=admin@your-domain.com

# Порты (публичный порт → внутренний)
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PORT=3000

# Домен (для nginx / HTTPS)
DOMAIN=semaphore.your-domain.com

# Логирование
RUST_LOG=info

# Временные файлы задач
SEMAPHORE_TMP_PATH=/tmp/semaphore
