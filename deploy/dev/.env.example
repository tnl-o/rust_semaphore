# ============================================================
# Velum — Development environment variables
# Скопируй в .env — docker compose подберёт автоматически
# ============================================================

# PostgreSQL
POSTGRES_DB=semaphore
POSTGRES_USER=semaphore
POSTGRES_PASSWORD=semaphore_dev_pass

# Backend
SEMAPHORE_JWT_SECRET=dev-jwt-secret-change-in-prod
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_PASSWORD=admin123
SEMAPHORE_ADMIN_NAME=Developer
SEMAPHORE_ADMIN_EMAIL=dev@localhost

# Порты
BACKEND_PORT=3000
DB_PORT=5432

# Rust логирование (debug для разработки)
RUST_LOG=semaphore=debug,tower_http=debug,sqlx=warn
RUST_BACKTRACE=1
