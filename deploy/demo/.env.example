# ============================================================
# Velum — Demo environment variables
# Скопируй в .env и измени при необходимости
# ============================================================

# Порт, на котором будет доступен UI (http://localhost:PORT)
VELUM_PORT=8088

# Учётные данные администратора (для автосида при первом запуске)
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_PASSWORD=admin123
SEMAPHORE_ADMIN_NAME=Administrator
SEMAPHORE_ADMIN_EMAIL=admin@semaphore.local

# JWT-секрет (можно оставить по умолчанию для demo)
SEMAPHORE_JWT_SECRET=demo-jwt-secret-not-for-production
