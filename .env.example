# Пример .env файла для локальной разработки
#
# ВАЖНО: Для PostgreSQL и MySQL необходимо использовать VELUM_DB_URL
# Отдельные переменные VELUM_DB_HOST, VELUM_DB_USER и т.д. НЕ работают!

# ============================================================================
# ВАРИАНТ 1: PostgreSQL (по умолчанию, рекомендуется)
# ============================================================================
VELUM_DB_DIALECT=postgres
VELUM_DB_URL=postgres://velum:velum_pass@localhost:5432/velum

# ============================================================================
# ВАРИАНТ 2: SQLite (только для быстрого тестирования)
# ============================================================================
# Раскомментируйте для использования SQLite:
# VELUM_DB_DIALECT=sqlite
# VELUM_DB_PATH=/tmp/velum.db
# VELUM_DB_URL=sqlite:///tmp/velum.db

# ============================================================================
# ВАРИАНТ 3: MySQL
# ============================================================================
# Раскомментируйте для использования MySQL:
# VELUM_DB_DIALECT=mysql
# VELUM_DB_URL=mysql://velum:velum_pass@localhost:3306/velum

# ============================================================================
# УСТАРЕВШИЕ ПЕРЕМЕННЫЕ (НЕ ИСПОЛЬЗУЮТСЯ!)
# ============================================================================
# Следующие переменные НЕ работают в Rust версии:
# - VELUM_DB_HOST
# - VELUM_DB_PORT
# - VELUM_DB_USER
# - VELUM_DB_PASS
# - VELUM_DB_NAME
# Используйте VELUM_DB_URL вместо них!

# ============================================================================
# HTTP сервер
# ============================================================================
VELUM_TCP_ADDRESS=0.0.0.0:3000
VELUM_WEB_PATH=./web/public

# ============================================================================
# JWT секрет (обязательно измените для продакшена!)
# ============================================================================
# VELUM_JWT_SECRET=your-secure-random-string-at-least-32-chars

# ============================================================================
# Логирование
# ============================================================================
RUST_LOG=info
# Варианты: error, warn, info, debug, trace

# ============================================================================
# Временная директория
# ============================================================================
VELUM_TMP_PATH=/tmp/velum

# ============================================================================
# HA режим (High Availability) - опционально
# ============================================================================
# VELUM_HA_ENABLE=false
# VELUM_HA_REDIS_HOST=localhost
# VELUM_HA_REDIS_PORT=6379

# ============================================================================
# LDAP - опционально
# ============================================================================
# VELUM_LDAP_ENABLE=false
# VELUM_LDAP_SERVER=ldap://localhost:389

# ============================================================================
# TOTP (двухфакторная аутентификация) - опционально
# ============================================================================
# VELUM_AUTH_TOTP_ENABLE=false
# VELUM_AUTH_TOTP_ALLOW_RECOVERY=true
